# ==================== 智慧党建智能体 - 环境配置 ====================

# ---- DeepSeek API ----
# 方式一：DeepSeek 云端 API
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com

# 方式二：本地 ollama 部署（注释上面，取消下面注释）
# DEEPSEEK_API_BASE=http://localhost:11434/v1
# DEEPSEEK_API_KEY=ollama
# DEEPSEEK_MODEL=deepseek-r1:7b

# ---- LLM 配置 ----
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ---- 嵌入模型 ----
# 可选: BAAI/bge-large-zh-v1.5, shibing624/text2vec-base-chinese
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024

# ---- MySQL 数据库 ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=party_building
DB_USER=root
DB_PASSWORD=your_password_here

# ---- Milvus 向量数据库 ----
# 类型: milvus（Milvus Lite 开发 / 独立服务生产）
VECTOR_STORE_TYPE=milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USE_LITE=true   # 开发环境 true（嵌入式），生产环境 false

# ---- Redis（可选，用于缓存和会话管理） ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- 应用配置 ----
APP_NAME=智慧党建智能体
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
