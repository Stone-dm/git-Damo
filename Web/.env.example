MYSQL_HOST=localhost
# Docker Compose 默认把 MySQL 映到宿主机 3307（避开本机已有 3306）
MYSQL_PORT=3307
MYSQL_DB=party_school
MYSQL_USER=party
MYSQL_PASSWORD=party123

# 使用本机已有的 Milvus 时保持 19530；不要再 docker compose --profile milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

JWT_SECRET=change-me-to-a-long-random-string
AGENT_BASE_URL=http://localhost:8000
# Optional shared secret for Backend → Agent (X-Agent-Token). Empty = open agent (dev).
AGENT_SHARED_TOKEN=
BACKEND_BASE_URL=http://localhost:8080
